{
  "name": "lkh-skynet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev",
    "db:local": "docker compose -f docker-compose.local.yml up -d && node scripts/wait-for-local-db.mjs && prisma migrate deploy",
    "seed:lkh:june": "VITEST=true tsx scripts/seed-lkh-periods.ts --months=2026-06",
    "seed:lkh:periods": "VITEST=true tsx scripts/seed-lkh-periods.ts",
    "seed:auth": "VITEST=true tsx scripts/seed-auth-users.ts",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run tests/unit.test.ts",
    "test:db": "docker compose -f docker-compose.test.yml up -d && node scripts/wait-for-test-db.mjs && DATABASE_URL=postgresql://lkh:lkh@127.0.0.1:55432/lkh_test npx prisma migrate deploy && DATABASE_URL=postgresql://lkh:lkh@127.0.0.1:55432/lkh_test vitest run tests/db.test.ts",
    "test:all": "npm run lint && DATABASE_URL=postgresql://user:pass@localhost:5432/lkh npx prisma validate && npm run test && npm run test:db && npm run build"
  },
  "dependencies": {
    "@coreui/coreui": "^5.7.1",
    "@coreui/icons": "^3.1.0",
    "@coreui/icons-react": "^2.3.0",
    "@coreui/react": "^5.11.0",
    "@popperjs/core": "^2.11.8",
    "@prisma/client": "^6.19.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/multer": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "lucide-react": "^0.546.0",
    "multer": "^2.1.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "sass": "^1.101.0",
    "simplebar-react": "^3.3.2",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.8"
  }
}
